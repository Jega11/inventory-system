ADD TABLE "Role"
  AREA "Data Area"
  DUMP-NAME "Role"

ADD FIELD "roleId" OF "Role" AS integer FORMAT ">>>>9" INITIAL "0" POSITION 3 ORDER 10
ADD FIELD "roleName" OF "Role" AS character FORMAT "x(30)" INITIAL "" POSITION 4 ORDER 20

ADD INDEX "roleId" ON "Role" AREA "Index Area" UNIQUE PRIMARY INDEX-FIELD "roleId" ASCENDING
.
PSC
cpstream=ISO8859-1
.
